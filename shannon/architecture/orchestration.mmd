flowchart TB
    subgraph Workflow["pentestPipeline(input) — Temporal Workflow"]
        W1["SELECT ACTIVITY PROXY<br/>pipelineTestingMode → testActs<br/>retry_preset=subscription → subscriptionActs<br/>else → acts (production)"]
        W2["INIT PIPELINE STATE<br/>status=running, startTime=Date.now()<br/>currentPhase, currentAgent,<br/>completedAgents[], agentMetrics{}"]
        W3["REGISTER QUERY HANDLER<br/>getProgress → PipelineProgress<br/>enables real-time status polling"]
        W4["BUILD ACTIVITY INPUT<br/>sessionId = resumeFromWorkspace<br/>?? sessionId ?? workflowId"]
        W5["RESUME LOGIC<br/>loadResumeState → restoreGitCheckpoint<br/>→ short-circuit check → recordResumeAttempt"]
    end

    subgraph Phases["5 PHASES (sequential + parallel)"]
        PH1["PHASE 0: PREFLIGHT<br/>preflightActs (3 retries, 1m)<br/>runPreflightValidation<br/>syncPlaywrightStealthConfig<br/>authValidationActs (3 retries, 10m)<br/>runAuthenticationValidation"]
        PH2["PHASE 1: PRE-RECON<br/>runSequentialPhase()<br/>pre-recon agent (Opus)"]
        PH3["PHASE 2: RECON<br/>runSequentialPhase()<br/>recon agent (Sonnet)"]
        PH4["PHASE 3-4: VULN + EXPLOIT<br/>runWithConcurrencyLimit(5)<br/>5 parallel pipelines<br/>Each: vuln → queue check → exploit"]
        PH5["PHASE 5: REPORTING<br/>assembleReport → report agent<br/>→ injectMetadata → generateOutput"]
    end

    subgraph ParallelPipeline["PER-VULN-CLASS PIPELINE (×5)"]
        PP1["runVulnExploitPipeline()"]
        PP2["Vuln Agent<br/>→ AgentMetrics stored"]
        PP3["mergeFindingsIntoQueue<br/>→ SAST external findings"]
        PP4["checkExploitationQueue<br/>→ ExploitationDecision"]
        PP5{"shouldExploit<br/>&& exploit?"}
        PP6["Exploit Agent<br/>→ AgentMetrics stored"]
        PP7["Skip exploit<br/>for this class"]
        PP8["Return VulnExploitPipelineResult<br/>vulnMetrics + exploitMetrics<br/>+ exploitDecision + error"]
    end

    subgraph RetryConfigs["5 RETRY CONFIGURATIONS"]
        RC1["PRODUCTION (default)<br/>50 attempts, 5m-30m backoff<br/>2h timeout"]
        RC2["TESTING (testing mode)<br/>5 attempts, 10s-30s backoff<br/>30m timeout"]
        RC3["SUBSCRIPTION (retry_preset)<br/>100 attempts, 5m-6h backoff<br/>8h timeout"]
        RC4["PREFLIGHT<br/>3 attempts, 10s-1m backoff<br/>2m timeout"]
        RC5["AUTH VALIDATION<br/>3 attempts, 10s-1m backoff<br/>10m timeout"]
    end

    subgraph ErrorClassification["ERROR CLASSIFICATION"]
        EC1["ApplicationFailure types → ErrorCode<br/>BillingError → BILLING_ERROR<br/>RateLimitError → API_RATE_LIMITED<br/>ConfigurationError → CONFIG_VALIDATION_FAILED<br/>OutputValidationError → OUTPUT_VALIDATION_FAILED<br/>InvalidTargetError → TARGET_UNREACHABLE"]
        EC2["Format for workflow log<br/>formatWorkflowError()<br/>'Pipeline failed|type|message|hint'"]
        EC3["Remediation hints per type<br/>e.g., 'Check billing dashboard'"]
    end

    subgraph NonRetryable["NON-RETRYABLE ERROR TYPES"]
        NR1["AuthenticationError"]
        NR2["PermissionError"]
        NR3["InvalidRequestError"]
        NR4["RequestTooLargeError"]
        NR5["ConfigurationError"]
        NR6["InvalidTargetError"]
        NR7["ExecutionLimitError"]
        NR8["AuthLoginFailedError"]
    end

    W1 --> W2 --> W3 --> W4 --> W5
    W5 --> Phases
    PH1 --> PH2 --> PH3 --> PH4 --> PH5

    PH4 --> ParallelPipeline
    PP1 --> PP2 --> PP3 --> PP4 --> PP5
    PP5 -->|"Yes"| PP6 --> PP8
    PP5 -->|"No"| PP7 --> PP8

    PH1 -..- RC4
    PH1 -..- RC5
    PH2 -..- RC1
    PH2 -..- RC2
    PH2 -..- RC3

    PH4 --> ErrorClassification
    ErrorClassification --> NonRetryable

    note right of RetryConfigs
        NON-RETRYABLE TYPES
        (shared across all configs):
        AuthenticationError
        PermissionError
        InvalidRequestError
        RequestTooLargeError
        ConfigurationError
        InvalidTargetError
        ExecutionLimitError
        AuthLoginFailedError
    end note

    note right of Workflow
        ERROR HANDLING:
        isCancellation → status='cancelled'
        + graceful return
        Failure → status='failed'
        + classifyErrorCode
        + formatWorkflowError
        + THROW for Temporal retry
    end note
